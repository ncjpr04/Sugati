<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>sugati__O_TOMS_Post_Margin__c</fullName>
    <deprecated>false</deprecated>
    <externalId>false</externalId>
    <formula>IF(
    ISBLANK(sugati__S_O_TOMS_Charges_Overwrite__c) &amp;&amp; ISBLANK(sugati__O_TOMS_Charges__c),
    0,
    ((sugati__O_TOMS_Applicable_Margin__c - 
      BLANKVALUE(sugati__S_O_TOMS_Charges_Overwrite__c, sugati__O_TOMS_Charges__c)) / 
      sugati__S_O_Total_Gross_Sell_Price_Selling__c) * 100
)</formula>
    <label>TOMS Post Margin %</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
